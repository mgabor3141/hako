workspace/
.env
# local, host-specific test wiring (e.g. notify-send desktop approval)
compose.override.yaml
gateway/hooks.local/
# anything *.local is host-local and never committed (e.g. eval/.env.local with API keys)
*.local*
# the age-encrypted secret vault is user data, never committed
vault/
# user's enabled-integration set + generated gateway config
hako.toml
gateway/config.json
.hako.env
# compiled launcher binary (built from launcher/*.go)
launcher/hako

# launcher: pinned-binary download cache + goreleaser output
.hako/
dist/

# backups integration: isolated restic repo (must stay unreachable by the agent)
/backups/

# compiled launcher binary from a bare `go build ./...` in launcher/
/launcher/launcher

# Benchmark run artifacts (transcripts/scores); summaries go in eval/BASELINE.md
eval/results/
