{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "file",
    "source": "/home/agent/.config/fastfetch/hako.txt",
    "color": { "1": "cyan" },
    "padding": { "top": 0, "right": 3 }
  },
  "display": { "separator": "   " },
  "modules": [
    { "type": "shell", "key": "Shell  " },
    { "type": "command", "key": "Connect", "text": "if [ -n \"$GMUX\" ]; then echo 'type  pi  to launch the agent'; else echo 'http://localhost:8791   (token: gmuxd auth)'; fi" },
    { "type": "command", "key": "Source ", "text": "echo github.com/mgabor3141/hako" }
  ]
}
