# The mounted home accumulates tool caches (.bun, .npm), pi runtime state
# (auth.json, sessions, installed packages), and the user's own projects.
# hako commits ONLY its shipped opinions; everything else is ignored.

# Ignore everything by default...
*

# ...except this file, the shell config, and the shipped pi opinions.
!.gitignore
!.zshrc
!.default-python-packages
!.pi/
.pi/*
!.pi/agent/
.pi/agent/*
!.pi/agent/settings.json
!.pi/agent/AGENTS.md
!.pi/agent/prompts/
!.pi/agent/prompts/**
!.pi/agent/skills/
!.pi/agent/skills/**
!.pi/agent/extensions/
!.pi/agent/extensions/**
# ...but *.local.ts extensions are host-local (personal providers/keys): pi still
# auto-loads them (they match *.ts), they're just never committed.
.pi/agent/extensions/*.local.ts
!.config/
.config/*
!.config/starship.toml
!.config/git/
.config/git/*
!.config/git/config
!.config/mise/
.config/mise/*
!.config/mise/config.toml
!.config/mise/mise.lock
!.config/mise/bash-env.sh
