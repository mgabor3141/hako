#!/bin/sh
# Unseal the gateway (ADR-0011). Run inside the gateway container:
#   printf '%s' "$passphrase" | docker exec -i hako-gateway /seal/hako-unlock
#
# Reads the passphrase on stdin, age-decrypts /vault/github.age into the tmpfs at
# /run/hako/token (0600) for boot.sh. age won't take a passphrase from a pipe,
# so it's pty-wrapped via `script` (bsdutils). The plaintext only ever lands in
# tmpfs (RAM); the passphrase is never stored.
set -eu
vault="/vault/github.age"
tok="/run/hako/token"
[ -f "$vault" ] || { echo "hako-unlock: no vault at $vault" >&2; exit 1; }

pass="$(cat)"            # passphrase on stdin (trailing newline stripped)
mkdir -p "$(dirname "$tok")"
umask 077

if printf '%s\n' "$pass" | script -qec "age -d -o '$tok.part' '$vault'" /dev/null >/dev/null 2>&1 \
   && [ -s "$tok.part" ]; then
  mv "$tok.part" "$tok"
  echo "hako-unlock: unsealed."
else
  rm -f "$tok.part"
  echo "hako-unlock: FAILED (wrong passphrase or bad vault)" >&2
  exit 1
fi
