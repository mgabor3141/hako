#!/bin/sh
# hako -- bootstrap for the host launcher (ADR-0012).
#
# Builds the Go launcher in launcher/ and execs it, caching the binary by a hash
# of that source so it rebuilds only when the source changes. Uses the host Go
# toolchain when present; otherwise builds in a pinned container -- Docker is
# hako's one hard dependency. No release pipeline and no downloaded binary: you
# always run a build of the exact source in your checkout.
#
# HAKO_FORCE_CONTAINER=1 builds in the container even when host Go is present.
set -eu

unset CDPATH
here=$(cd -- "$(dirname -- "$0")" && pwd)
src="$here/launcher"

# Pinned Go toolchain for the container build (ADR-0008); = golang:1.23-alpine.
builder="golang:1.23-alpine@sha256:383395b794dffa5b53012a212365d40c8e37109a626ca30d6151c8348d380b5f"

sha256() { if command -v sha256sum >/dev/null 2>&1; then sha256sum; else shasum -a 256; fi; }

# Cache key: a content hash of the launcher source (clone-stable, unlike mtimes).
hash=$(cd "$src" && { find . -type f \( -name '*.go' -o -name 'go.mod' -o -name 'go.sum' \) \
  | sort | while IFS= read -r f; do printf '== %s\n' "$f"; cat "$f"; done; } | sha256 | cut -c1-16)
bin="$here/.hako/$hash/hako"

if [ ! -x "$bin" ]; then
  mkdir -p "$(dirname "$bin")"
  if [ "${HAKO_FORCE_CONTAINER:-0}" != 1 ] && command -v go >/dev/null 2>&1; then
    ( cd "$src" && go build -trimpath -ldflags "-X main.version=$hash" -o "$bin" . )
  else
    command -v docker >/dev/null 2>&1 || { echo "hako: need Go or Docker to build the launcher." >&2; exit 1; }
    echo "hako: building the launcher in a container (one-time, until the source changes)..." >&2
    cache="$here/.hako/cache"
    mkdir -p "$cache"
    docker run --rm \
      --user "$(id -u):$(id -g)" \
      -v "$src:/src:ro" -v "$cache:/cache" -v "$(dirname "$bin"):/out" -w /src \
      -e GOCACHE=/cache/build -e GOMODCACHE=/cache/mod -e HOME=/cache \
      "$builder" go build -trimpath -ldflags "-X main.version=$hash" -o /out/hako .
  fi
fi

cd "$here"
exec "$bin" "$@"
