#!/bin/sh
# hako -- bootstrap for the host launcher (ADR-0012).
#
# Builds the Go launcher in launcher/ on first run (or whenever its source
# changes) and execs it. This is the interim form of model C: once CI publishes
# pinned, checksummed release binaries, this script will download and verify one
# instead of building. Until then it builds locally, which needs a Go toolchain.
set -eu

unset CDPATH
here=$(cd -- "$(dirname -- "$0")" && pwd)
bin="$here/launcher/hako"
src="$here/launcher"

# (re)build when the binary is missing or older than any source file
if [ ! -x "$bin" ] || [ -n "$(find "$src" \( -name '*.go' -o -name 'go.mod' -o -name 'go.sum' \) -newer "$bin" 2>/dev/null)" ]; then
  if ! command -v go >/dev/null 2>&1; then
    echo "hako: building the launcher needs Go (https://go.dev/dl/). Prebuilt releases are coming." >&2
    exit 1
  fi
  ( cd "$src" && go build -o hako . )
fi

cd "$here"
exec "$bin" "$@"
