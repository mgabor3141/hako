{
  "transportType": "streamable-http",
  "url": "https://api.githubcopilot.com/mcp/",
  "headers": {
    "Authorization": "Bearer ${GITHUB_MCP_TOKEN}"
  },
  "options": {
    "logEnabled": true,
    "callHook": {
      "command": ["/hooks/approve.sh"],
      "requireFor": [
        "create_pull_request",
        "update_pull_request",
        "merge_pull_request",
        "add_issue_comment",
        "issue_write",
        "pull_request_review_write",
        "actions_run_trigger"
      ]
    }
  }
}
